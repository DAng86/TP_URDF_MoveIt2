<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="clean_robot_arm">

  <material name="base_grey">
    <color rgba="0.45 0.45 0.45 1"/>
  </material>

  <material name="arm_blue">
    <color rgba="0.0 0.25 1.0 1"/>
  </material>

  <material name="arm_orange">
    <color rgba="1.0 0.55 0.0 1"/>
  </material>

  <material name="gripper_black">
    <color rgba="0.02 0.02 0.02 1"/>
  </material>

  <!-- World frame -->
  <link name="world"/>

  <!-- Base -->
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0.15" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.45" length="0.30"/>
      </geometry>
      <material name="base_grey"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.15" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.45" length="0.30"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0.15"/>
      <mass value="5.0"/>
      <inertia ixx="0.1" ixy="0" ixz="0" iyy="0.1" iyz="0" izz="0.1"/>
    </inertial>
  </link>

  <joint name="world_to_base" type="fixed">
    <parent link="world"/>
    <child link="base_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- Shoulder vertical column -->
  <link name="shoulder_link">
    <visual>
      <origin xyz="0 0 0.55" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.18" length="1.10"/>
      </geometry>
      <material name="arm_blue"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.55" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.18" length="1.10"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0.55"/>
      <mass value="3.0"/>
      <inertia ixx="0.05" ixy="0" ixz="0" iyy="0.05" iyz="0" izz="0.05"/>
    </inertial>
  </link>

  <joint name="joint1" type="revolute">
    <parent link="base_link"/>
    <child link="shoulder_link"/>
    <origin xyz="0 0 0.30" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14" upper="3.14" effort="50" velocity="1.0"/>
  </joint>

  <!-- Upper arm -->
  <link name="upper_arm_link">
    <visual>
      <origin xyz="0.75 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="1.50 0.22 0.22"/>
      </geometry>
      <material name="arm_orange"/>
    </visual>
    <collision>
      <origin xyz="0.75 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="1.50 0.22 0.22"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0.75 0 0"/>
      <mass value="2.5"/>
      <inertia ixx="0.04" ixy="0" ixz="0" iyy="0.04" iyz="0" izz="0.04"/>
    </inertial>
  </link>

  <joint name="joint2" type="revolute">
    <parent link="shoulder_link"/>
    <child link="upper_arm_link"/>
    <origin xyz="0 0 1.10" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.57" upper="1.57" effort="50" velocity="1.0"/>
  </joint>

  <!-- Forearm -->
  <link name="forearm_link">
    <visual>
      <origin xyz="0.65 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="1.30 0.18 0.18"/>
      </geometry>
      <material name="arm_blue"/>
    </visual>
    <collision>
      <origin xyz="0.65 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="1.30 0.18 0.18"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0.65 0 0"/>
      <mass value="2.0"/>
      <inertia ixx="0.03" ixy="0" ixz="0" iyy="0.03" iyz="0" izz="0.03"/>
    </inertial>
  </link>

  <joint name="joint3" type="revolute">
    <parent link="upper_arm_link"/>
    <child link="forearm_link"/>
    <origin xyz="1.50 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.57" upper="1.57" effort="50" velocity="1.0"/>
  </joint>

  <!-- Wrist -->
  <link name="wrist_link">
    <visual>
      <origin xyz="0.25 0 0" rpy="0 1.5708 0"/>
      <geometry>
        <cylinder radius="0.15" length="0.50"/>
      </geometry>
      <material name="gripper_black"/>
    </visual>
    <collision>
      <origin xyz="0.25 0 0" rpy="0 1.5708 0"/>
      <geometry>
        <cylinder radius="0.15" length="0.50"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0.25 0 0"/>
      <mass value="1.0"/>
      <inertia ixx="0.02" ixy="0" ixz="0" iyy="0.02" iyz="0" izz="0.02"/>
    </inertial>
  </link>

  <joint name="joint4" type="revolute">
    <parent link="forearm_link"/>
    <child link="wrist_link"/>
    <origin xyz="1.30 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.57" upper="1.57" effort="30" velocity="1.0"/>
  </joint>

  <!-- Gripper palm -->
  <link name="gripper_link">
    <visual>
      <origin xyz="0.25 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.50 0.35 0.22"/>
      </geometry>
      <material name="arm_orange"/>
    </visual>
    <collision>
      <origin xyz="0.25 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.50 0.35 0.22"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0.25 0 0"/>
      <mass value="1.0"/>
      <inertia ixx="0.02" ixy="0" ixz="0" iyy="0.02" iyz="0" izz="0.02"/>
    </inertial>
  </link>

  <joint name="joint5" type="revolute">
    <parent link="wrist_link"/>
    <child link="gripper_link"/>
    <origin xyz="0.50 0 0" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-1.57" upper="1.57" effort="30" velocity="1.0"/>
  </joint>

  <!-- Left gripper finger -->
  <link name="left_finger_link">
    <visual>
      <origin xyz="0.35 0.18 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.70 0.08 0.12"/>
      </geometry>
      <material name="gripper_black"/>
    </visual>
    <collision>
      <origin xyz="0.35 0.18 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.70 0.08 0.12"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0.35 0.18 0"/>
      <mass value="0.3"/>
      <inertia ixx="0.005" ixy="0" ixz="0" iyy="0.005" iyz="0" izz="0.005"/>
    </inertial>
  </link>

  <joint name="left_finger_joint" type="fixed">
    <parent link="gripper_link"/>
    <child link="left_finger_link"/>
    <origin xyz="0.50 0 0" rpy="0 0 0"/>
  </joint>

  <!-- Right gripper finger -->
  <link name="right_finger_link">
    <visual>
      <origin xyz="0.35 -0.18 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.70 0.08 0.12"/>
      </geometry>
      <material name="gripper_black"/>
    </visual>
    <collision>
      <origin xyz="0.35 -0.18 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.70 0.08 0.12"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0.35 -0.18 0"/>
      <mass value="0.3"/>
      <inertia ixx="0.005" ixy="0" ixz="0" iyy="0.005" iyz="0" izz="0.005"/>
    </inertial>
  </link>

  <joint name="right_finger_joint" type="fixed">
    <parent link="gripper_link"/>
    <child link="right_finger_link"/>
    <origin xyz="0.50 0 0" rpy="0 0 0"/>
  </joint>

</robot>
